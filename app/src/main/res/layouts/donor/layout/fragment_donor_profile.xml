<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_vertical_gradient">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="24dp">

        <!-- 1. MODERN FLOATING HEADER -->
        <View
            android:id="@+id/vHeaderSpacer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@id/cardIdentity"
            app:layout_constraintHeight_percent="0.08"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="spread" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardIdentity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="32dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toTopOf="@id/llQuickActions"
            app:layout_constraintTop_toBottomOf="@id/vHeaderSpacer">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:paddingBottom="24dp">

                <!-- Profile Image overlapping the top -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/ivUserAvatarLayout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardCornerRadius="80dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:strokeColor="@color/white"
                    app:strokeWidth="2dp">

                    <ImageView
                        android:id="@+id/ivUserAvatar"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_launcher_background"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </com.google.android.material.card.MaterialCardView>
                <!--            <com.google.android.material.imageview.ShapeableImageView-->
                <!--                android:id="@+id/ivUserAvatar"-->
                <!--                android:layout_width="90dp"-->
                <!--                android:layout_height="90dp"-->
                <!--                android:layout_marginTop="20dp"-->
                <!--                android:background="@color/love_primary"-->
                <!--                android:padding="3dp"-->
                <!--                android:scaleType="centerCrop"-->
                <!--                android:src="@drawable/bg_splash"-->
                <!--                app:layout_constraintEnd_toEndOf="parent"-->
                <!--                app:layout_constraintStart_toStartOf="parent"-->
                <!--                app:layout_constraintTop_toTopOf="parent"-->
                <!--                app:shapeAppearanceOverlay="@style/CircleImage" />-->

                <TextView
                    android:id="@+id/tvProfileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/moniqa_black_paragraph"
                    android:letterSpacing="0.1"
                    android:text="JASON BROOKS"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:textSize="22sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/ivUserAvatarLayout" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.15"
                    android:text="Authorized User • System Active"
                    android:textAllCaps="true"
                    android:textColor="@color/love_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvProfileName" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 2. MINIMALIST UNIT TOGGLE CHIPS -->
        <LinearLayout
            android:id="@+id/llQuickActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toTopOf="@id/layoutEmergency"
            app:layout_constraintTop_toBottomOf="@id/cardIdentity">

            <com.google.android.material.chip.Chip
                android:id="@+id/editProfileInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="Edit Profile"
                android:textAppearance="@style/AppTheme.GenderChip"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:letterSpacing="0.02"
                app:chipBackgroundColor="@color/black"
                app:chipCornerRadius="12dp"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSafetyRules"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Safety Rule"
                android:textAppearance="@style/AppTheme.GenderChip"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:letterSpacing="0.01"
                app:chipBackgroundColor="@color/black"
                app:chipCornerRadius="12dp"
                app:chipStrokeWidth="0dp" />
        </LinearLayout>

        <!-- 3. FANCY EMERGENCY VITALS & EDIT INFO SECTION -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutEmergency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toTopOf="@id/mcvEmail"
            app:layout_constraintTop_toBottomOf="@id/llQuickActions">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/mcvEmergency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_card"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/tvIceLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.2"
                        android:text="SPECIFIED ROLE"
                        android:textColor="#888888"
                        android:textSize="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <View
                        android:id="@+id/vIndicator"
                        android:layout_width="4dp"
                        android:layout_height="40dp"
                        android:layout_marginTop="12dp"
                        android:background="@color/love_primary"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvIceLabel" />

                    <TextView
                        android:id="@+id/tvRoleType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:fontFamily="@font/moniqa_black_paragraph"
                        android:text="VOLUNTEER"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        app:layout_constraintStart_toEndOf="@id/vIndicator"
                        app:layout_constraintTop_toTopOf="@id/vIndicator" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Verified Role"
                        android:textColor="#666666"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@id/tvRoleType"
                        app:layout_constraintTop_toBottomOf="@id/tvRoleType" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!--        <com.google.android.material.card.MaterialCardView-->
            <!--            android:id="@+id/editProfileInfo"-->
            <!--            android:layout_width="0dp"-->
            <!--            android:layout_height="0dp"-->
            <!--            app:layout_constraintWidth_percent="0.15"-->
            <!--            app:cardBackgroundColor="@android:color/transparent"-->
            <!--            app:cardCornerRadius="25dp"-->
            <!--            app:cardElevation="0dp"-->
            <!--            app:layout_constraintEnd_toEndOf="parent"-->
            <!--            app:layout_constraintTop_toTopOf="@id/mcvEmergency"-->
            <!--            app:layout_constraintBottom_toBottomOf="@id/mcvEmergency"-->
            <!--            android:clipChildren="false"-->
            <!--            android:clipToPadding="false">-->

            <!--            <com.mohitladhe.vitals.widgets.VerticalMarqueeTextView-->
            <!--                android:id="@+id/marquee"-->
            <!--                android:layout_width="wrap_content"-->
            <!--                android:layout_height="match_parent"-->
            <!--                android:paddingTop="20dp"-->
            <!--                android:paddingBottom="10dp"-->
            <!--                android:gravity="center"-->
            <!--                android:clipChildren="true"-->
            <!--                android:clipToPadding="true"-->
            <!--                android:textSize="20sp"-->
            <!--                android:textColor="@color/black"-->
            <!--                android:lineSpacingExtra="2dp"-->
            <!--                android:scaleX="1.5"-->
            <!--                app:marqueeSpeed="15"-->
            <!--                app:marqueeText="E\nD\nI\nT\nP\nR\nO\nF\nI\nL\nE"-->
            <!--                android:background="@drawable/bg_glass_card"/>-->

            <!--        </com.google.android.material.card.MaterialCardView>-->

        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mcvEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="32dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toTopOf="@id/swipeLogout"
            app:layout_constraintTop_toBottomOf="@id/layoutEmergency">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvIceLabel2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.2"
                    android:text="EMAIL ID"
                    android:textColor="#888888"
                    android:textSize="10sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/vIndicator2"
                    android:layout_width="4dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="12dp"
                    android:background="@color/love_primary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvIceLabel2" />

                <TextView
                    android:id="@+id/tvEmail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_constraintWidth_percent="0.9"
                    android:layout_marginStart="12dp"
                    android:fontFamily="@font/moniqa_black_paragraph"
                    android:text="krishnarajegunjal4488@gmail.com"
                    android:textColor="@color/black"
                    android:maxLines="1"
                    android:singleLine="true"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="8sp"
                    app:autoSizeMaxTextSize="18sp"
                    app:autoSizeStepGranularity="1sp"
                    app:layout_constraintStart_toEndOf="@id/vIndicator2"
                    app:layout_constraintTop_toTopOf="@id/vIndicator2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Verified Email ID"
                    android:textColor="#666666"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="@id/tvEmail"
                    app:layout_constraintTop_toBottomOf="@id/tvEmail" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 4. MINIMAL SLIDE TO LOGOUT -->
        <com.ncorti.slidetoact.SlideToActView
            android:id="@+id/swipeLogout"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            app:area_margin="8dp"
            app:icon_margin="12dp"
            app:inner_color="@color/black"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/mcvEmail"
            app:outer_color="#12000000"
            app:slider_icon="@drawable/ic_logout_svg"
            app:slider_icon_color="@color/love_primary"
            app:text="Log Out     >>>"
            app:text_appearance="@font/moniqa_black_paragraph"
            app:text_color="@color/black"
            app:text_size="18sp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 5. SAFETY RULES OVERLAY -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutSafetyRulesOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/blur"
        android:clickable="true"
        android:elevation="20dp"
        android:focusable="true"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="32dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvSafetyTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/moniqa_black_paragraph"
                    android:letterSpacing="0.1"
                    android:text="SAFETY RULES"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnCloseSafety"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    app:cardBackgroundColor="@color/black"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_close"
                        app:tint="@color/love_primary" />
                </com.google.android.material.card.MaterialCardView>

                <View
                    android:id="@+id/vSeparator"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:background="#1A000000"
                    app:layout_constraintTop_toBottomOf="@id/tvSafetyTitle" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    app:layout_constraintTop_toBottomOf="@id/vSeparator">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="1. Seatbelts Mandatory"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="2. Maintain Speed Limits"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="3. No Distracted Driving"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="4. Keep Safe Distance"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="5. Respect Traffic Signs"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
