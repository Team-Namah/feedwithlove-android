<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_donor_upload"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/love_bg_warm"
    android:fitsSystemWindows="true"
    tools:context="ui.donor.DonorFoodUploadActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/love_bg_warm"
        app:liftOnScroll="false"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/love_bg_warm"
            app:navigationIcon="@drawable/ic_back_chevron"
            app:navigationIconTint="@color/love_text_deep"
            app:title="Share Your Meal"
            app:titleTextColor="@color/love_text_deep"
            app:titleTextAppearance="@style/AppTheme.MaterialToolbar"/>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Photo Upload Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/love_pink_soft"
                app:strokeWidth="2dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/love_surface">

                    <ImageView
                        android:id="@+id/ivFoodImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/layoutUploadPlaceholder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toTopOf="@+id/layoutButtons"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintVertical_chainStyle="packed">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:alpha="0.6"
                            android:src="@android:drawable/ic_menu_camera"
                            app:tint="@color/love_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Add Food Photos"
                            android:textColor="@color/love_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutButtons"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:orientation="horizontal"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCapture"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Camera"
                            android:textAllCaps="false"
                            android:textColor="@color/love_primary"
                            app:icon="@android:drawable/ic_menu_camera"
                            app:iconPadding="8dp"
                            app:iconTint="@color/love_primary" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:layout_marginHorizontal="8dp"
                            android:background="@color/love_pink_soft" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnGallery"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gallery"
                            android:textAllCaps="false"
                            android:textColor="@color/love_primary"
                            app:icon="@android:drawable/ic_menu_gallery"
                            app:iconPadding="8dp"
                            app:iconTint="@color/love_primary" />
                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Form Fields -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:hint="What are you donating?"
                android:textColorHint="@color/love_text_deep"
                app:boxBackgroundColor="@color/white"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/love_primary"
                app:hintTextColor="@color/love_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFoodName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:paddingVertical="18dp"
                    android:textColor="@color/love_text_deep" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Quantity / Portions"
                android:textColorHint="@color/love_text_deep"
                app:boxBackgroundColor="@color/white"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/love_primary"
                app:hintTextColor="@color/love_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etQuantity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:paddingVertical="18dp"
                    android:textColor="@color/love_text_deep" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Pickup Location"
                android:textColorHint="@color/love_text_deep"
                app:boxBackgroundColor="@color/white"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/love_primary"
                app:hintTextColor="@color/love_primary"
                app:startIconDrawable="@drawable/ic_location"
                app:startIconTint="@color/love_primary"
                app:startIconMinSize="32dp"
                app:startIconScaleType="centerInside">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPostalAddress"
                    android:paddingVertical="18dp"
                    android:textColor="@color/love_text_deep" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Available Until (Time)"
                android:textColorHint="@color/love_text_deep"
                app:boxBackgroundColor="@color/white"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/love_primary"
                app:hintTextColor="@color/love_primary"
                app:startIconDrawable="@drawable/ic_time"
                app:startIconTint="@color/love_primary"
                app:startIconMinSize="32dp"
                app:startIconScaleType="centerInside">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="false"
                    android:paddingVertical="18dp"
                    android:textColor="@color/love_text_deep" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:visibility="gone"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Additional Notes (e.g. Allergens)"
                android:textColorHint="@color/love_text_deep"
                app:boxBackgroundColor="@color/white"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/love_primary"
                app:hintTextColor="@color/love_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNotes"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:padding="18dp"
                    android:textColor="@color/love_text_deep" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="36dp"
                android:layout_marginBottom="32dp"
                android:backgroundTint="@color/love_primary"
                android:elevation="4dp"
                android:fontFamily="@font/moniqa_black_paragraph"
                android:letterSpacing="0.08"
                android:text="Confirm Donation"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textSize="20sp"
                app:cornerRadius="20dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>