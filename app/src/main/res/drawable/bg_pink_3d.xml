<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom Shadow/Depth -->
    <item>
        <shape>
            <solid android:color="#8E0E2F" />
            <corners android:radius="100dp" />
        </shape>
    </item>

    <!-- Main Gradient Surface -->
    <item android:bottom="6dp">
        <shape>
            <gradient
                android:angle="270"
                android:endColor="#FF4D6D"
                android:startColor="#FF85A1" />
            <corners android:radius="100dp" />
            <!-- Inner Light Highlight -->
            <stroke
                android:width="1.5dp"
                android:color="#4DFFFFFF" />
        </shape>
    </item>
</layer-list>